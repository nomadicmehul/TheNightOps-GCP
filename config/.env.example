# TheNightOps Environment Variables
# Copy this file to config/.env and fill in your values.

# ── Google Cloud Platform ──────────────────────────────────────────
# Used by official Google Cloud MCP servers (GKE, Cloud Observability)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── GKE Cluster ────────────────────────────────────────────────────
# Used by the official GKE MCP server
GKE_CLUSTER_NAME=nightops-demo
GKE_CLUSTER_LOCATION=us-central1-a

# ── Grafana (official MCP via mcp-grafana) ─────────────────────────
# Used by the official Grafana MCP server (stdio transport)
# Create a service account in Grafana → Administration → Service Accounts
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=your-grafana-service-account-token

# ── Slack (custom MCP server) ─────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── Notifications — Email (custom MCP server) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=nightops@yourcompany.com

# ── Notifications — Telegram (custom MCP server) ──────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Notifications — WhatsApp (custom MCP server) ──────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_NUMBER_ID/messages
WHATSAPP_API_TOKEN=your-whatsapp-business-api-token
WHATSAPP_PHONE_NUMBER=+1234567890

# ── Google AI (for ADK / Gemini model) ────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key

# ── Agent Configuration (optional overrides) ──────────────────────
# NIGHTOPS_MODEL=gemini-2.0-flash
# NIGHTOPS_MAX_INVESTIGATION_TIME=300
# NIGHTOPS_VERBOSE=false
